# Postgres connection for the new `asado` database on your Postgres LXC
DATABASE_URL=postgres://asado:CHANGE_ME@POSTGRES_LXC_IP:5432/asado

# Long random secret the frontend must send as: Authorization: Bearer <token>
# Generate one with:  openssl rand -hex 32
API_TOKEN=CHANGE_ME_LONG_RANDOM

# Port the API listens on
PORT=8787

# CORS origin allowed to call the API.
# LAN-only: "*" is fine (we use a bearer token, not cookies).
# Or set the exact origin you open the HTML from, e.g. http://10.0.0.50:5500
ALLOWED_ORIGIN=*

# Docker only: the VM's LAN or Tailscale IP to bind the published port to,
# so the API isn't exposed on every interface. e.g. 10.0.0.20 or your tailnet IP.
# NOTE: unused with the Tailscale-serve setup (HTTPS-only, no published port).
HOST_IP=0.0.0.0

# Tailscale sidecar (ts-asado): reusable auth key to register the per-app node.
# Generate at https://login.tailscale.com/admin/settings/keys (Reusable).
# Serves the app at https://asado.<your-tailnet>.ts.net/ (HTTPS, tailnet-only).
TS_AUTHKEY=tskey-auth-CHANGE_ME
